{
  "name": "@obscrd/svelte",
  "version": "0.2.2",
  "description": "Svelte components for content protection — obfuscate text, images, and contact info",
  "type": "module",
  "sideEffects": false,
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "svelte-package -i src -o dist",
    "dev": "svelte-package -i src -o dist --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "echo 'no tests yet'"
  },
  "dependencies": {
    "@obscrd/core": "workspace:*"
  },
  "devDependencies": {
    "@obscrd/typescript-config": "workspace:*",
    "@sveltejs/package": "^2.0.0",
    "@types/bun": "^1.3.10",
    "svelte": "^5.0.0"
  },
  "peerDependencies": {
    "svelte": ">=5.0.0"
  },
  "keywords": [
    "svelte",
    "anti-scraping",
    "content-protection",
    "obfuscation",
    "svelte-components",
    "ai-bot-protection"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/obscrd/obscrd.git",
    "directory": "packages/svelte"
  },
  "homepage": "https://obscrd.dev",
  "bugs": "https://github.com/obscrd/obscrd/issues"
}
