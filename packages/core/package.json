{
  "name": "@obscrd/core",
  "version": "0.2.4",
  "description": "Content protection engine — obfuscate text, trap scrapers, defend against AI bots",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "obscrd": "./dist/cli.cjs"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "postbuild": "chmod +x dist/cli.cjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "bun test"
  },
  "devDependencies": {
    "@obscrd/typescript-config": "workspace:*",
    "@types/node": "^25.3.5",
    "tsup": "^8.4.0"
  },
  "keywords": [
    "anti-scraping",
    "content-protection",
    "obfuscation",
    "ai-bot-protection",
    "web-security",
    "text-protection",
    "scraping-defense",
    "honeypot",
    "gptbot",
    "ai-crawler"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/obscrd/obscrd.git",
    "directory": "packages/core"
  },
  "homepage": "https://obscrd.dev",
  "bugs": "https://github.com/obscrd/obscrd/issues"
}
