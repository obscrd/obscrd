{
  "name": "@obscrd/angular",
  "version": "0.2.2",
  "description": "Angular components for content protection — obfuscate text, images, and contact info",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "echo 'no tests yet'"
  },
  "dependencies": {
    "@obscrd/core": "workspace:*"
  },
  "devDependencies": {
    "@obscrd/typescript-config": "workspace:*",
    "@angular/core": "^17.0.0",
    "@angular/common": "^17.0.0",
    "@angular/compiler": "^17.0.0",
    "@angular/platform-browser": "^17.0.0",
    "@types/bun": "^1.3.10",
    "tsup": "^8.4.0",
    "typescript": "~5.8.0"
  },
  "peerDependencies": {
    "@angular/core": ">=17.0.0",
    "@angular/common": ">=17.0.0",
    "@angular/platform-browser": ">=17.0.0"
  },
  "keywords": [
    "angular",
    "obfuscator",
    "content-protection",
    "security",
    "text-obfuscation",
    "css-obfuscation",
    "dom-protection",
    "canvas-protection",
    "angular-components",
    "encoder"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/obscrd/obscrd.git",
    "directory": "packages/angular"
  },
  "homepage": "https://obscrd.dev",
  "bugs": "https://github.com/obscrd/obscrd/issues"
}
