{
  "name": "@obscrd/vue",
  "version": "0.2.2",
  "description": "Vue components for content protection — obfuscate text, images, and contact info",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "bun test"
  },
  "dependencies": {
    "@obscrd/core": "workspace:*"
  },
  "devDependencies": {
    "@obscrd/typescript-config": "workspace:*",
    "@types/bun": "^1.3.10",
    "@types/jsdom": "^28.0.0",
    "jsdom": "^28.1.0",
    "tsup": "^8.4.0",
    "vue": "^3.4.0"
  },
  "peerDependencies": {
    "vue": ">=3.4.0"
  },
  "keywords": [
    "vue",
    "obfuscator",
    "content-protection",
    "security",
    "text-obfuscation",
    "css-obfuscation",
    "dom-protection",
    "canvas-protection",
    "vue-components",
    "encoder"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/obscrd/obscrd.git",
    "directory": "packages/vue"
  },
  "homepage": "https://obscrd.dev",
  "bugs": "https://github.com/obscrd/obscrd/issues"
}
